---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const rawNotes = (await getCollection('micro', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const notes = await Promise.all(
  rawNotes.map(async (note) => {
    const { Content } = await note.render();
    return { note, Content };
  })
);
const formatter = new Intl.DateTimeFormat('en-CA');
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Micro">
  <section class="content page">
    <h1>Micro</h1>
    <div class="feed">
      {notes.map(({ note, Content }) => (
        <article class="feed-item">
          <header class="item-head">
            <h2><a href={`${base}micro/${note.slug}/`}>{note.data.title}</a></h2>
            <time datetime={note.data.pubDate.toISOString()}>{formatter.format(note.data.pubDate)}</time>
          </header>
          {note.data.description && <p class="summary">{note.data.description}</p>}
          <div class="body prose">
            <Content />
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: 2rem;
  }

  h1 {
    font-size: 1.9rem;
    margin: 0;
    font-weight: 700;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 1.5rem;
  }

  .feed {
    display: grid;
    gap: 1rem;
  }

  .feed-item {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: color-mix(in oklab, var(--panel) 96%, transparent);
    padding: 1.1rem 1.2rem 1.15rem;
  }

  .item-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--line);
  }

  h2 {
    font-size: 0.98rem;
    line-height: 1.4;
    margin: 0;
    font-weight: 700;
  }

  .summary {
    margin: 0 0 0.7rem;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.5;
  }

  .body :global(p) {
    margin: 0.4rem 0 0;
    font-size: 0.97rem;
    line-height: 1.58;
  }

  .body :global(p:first-child) {
    margin-top: 0;
  }

  time {
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .feed {
      gap: 0.85rem;
    }

    .feed-item {
      padding: 0.95rem 1rem 1rem;
    }

    .item-head {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      margin-bottom: 0.65rem;
      padding-bottom: 0.6rem;
    }
  }
</style>

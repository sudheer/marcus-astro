---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = (await getCollection('micro', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const formatter = new Intl.DateTimeFormat('en-CA');
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Micro">
  <section class="content page">
    <h1>Micro</h1>
    <div class="cards">
      {notes.map((note) => (
        <article>
          <header>
            <h2><a href={`${base}micro/${note.slug}/`}>{note.data.title}</a></h2>
            <time datetime={note.data.pubDate.toISOString()}>{formatter.format(note.data.pubDate)}</time>
          </header>
          <p>{note.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: 2rem;
  }

  h1 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin-bottom: 2rem;
    font-weight: 680;
  }

  .cards {
    display: grid;
    gap: 1.2rem;
  }

  article {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: color-mix(in oklab, var(--panel) 95%, transparent);
    padding: 1.2rem 1.25rem;
  }

  header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.8rem;
    border-bottom: 1px solid var(--line);
  }

  h2 {
    font-size: 1.65rem;
    margin: 0 0 0.7rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 1.03rem;
  }

  time {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 640px) {
    header {
      grid-template-columns: 1fr;
    }
  }
</style>

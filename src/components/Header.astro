---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/', label: 'Home' },
  { href: '/posts', label: 'Posts' },
  { href: '/micro', label: 'Micro' }
];

const isActive = (href: string, pathname: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const pathname = Astro.url.pathname;
---

<header class="header shell">
  <div class="content row">
    <a href="/" class="brand">SuDo</a>
    <nav aria-label="Main">
      <ul>
        {links.map((link) => (
          <li>
            <a href={link.href} aria-current={isActive(link.href, pathname) ? 'page' : undefined}>
              {link.label}
            </a>
          </li>
        ))}
        <li><ThemeToggle /></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    padding: 2.25rem 0 1.1rem;
    border-bottom: 1px solid var(--line);
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.6rem;
    align-items: center;
  }

  nav a {
    font-weight: 650;
    color: var(--muted);
  }

  nav a[aria-current='page'] {
    color: var(--text);
  }

  @media (max-width: 740px) {
    .brand {
      font-size: 2.2rem;
    }

    ul {
      gap: 1rem;
      font-size: 0.95rem;
    }
  }
</style>
